{
  "name": "@zyx1121/apple-powerpoint-mcp",
  "version": "0.2.0",
  "description": "MCP server for Microsoft PowerPoint — create, edit, and export presentations via Claude Code",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "apple-powerpoint-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
